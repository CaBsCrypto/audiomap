rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // REGLAS DE ORO — ENJAMBRE 2: Firestore Security Rules
    // ══════════════════════════════════════════════════════════

    // Datos privados: solo el propietario puede leer/escribir
    match /artifacts/{appId}/users/{userId}/maps/{mapId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && isValidMapDocument();
    }

    // Datos públicos compartidos: solo lectura para todos (autenticados o no)
    // Solo escritura para usuarios autenticados
    match /artifacts/{appId}/public/data/shares/{shareId} {
      allow read: if true;
      allow write: if request.auth != null
                   && isValidShareDocument();
    }

    // ── Validadores de estructura de documento ─────────────────
    function isValidMapDocument() {
      let data = request.resource.data;
      return data.keys().hasAll(['nodes', 'updatedAt', 'mapId', 'userId'])
          && data.nodes is list
          && data.nodes.size() <= 200;    // Máximo 200 nodos por mapa
    }

    function isValidShareDocument() {
      let data = request.resource.data;
      return data.keys().hasAll(['nodes', 'createdAt', 'createdBy'])
          && data.nodes is list;
    }

    // Bloquear acceso a cualquier otra ruta
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
